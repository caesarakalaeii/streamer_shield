# StreamerShield local dev environment — managed by direnv.
# Auto-creates a project-local virtualenv, keeps deps in sync, and loads .env.
# Enable once with:  direnv allow
# The venv lives in ./.venv (gitignored); delete it to force a clean rebuild.

VENV=.venv

if [[ ! -x "$VENV/bin/python" ]]; then
  log_status "creating virtualenv ($(python3 --version 2>&1)) in $VENV"
  python3 -m venv "$VENV"
fi

# shellcheck disable=SC1091
source "$VENV/bin/activate"

# Install/refresh dev dependencies only when a requirements file changes.
if [[ -f requirements-dev.txt ]] && \
   { [[ ! -f "$VENV/.deps-stamp" ]] || \
     [[ requirements-dev.txt -nt "$VENV/.deps-stamp" ]] || \
     [[ requirements-bot.txt -nt "$VENV/.deps-stamp" ]]; }; then
  log_status "syncing python deps from requirements-dev.txt"
  python -m pip install --upgrade pip >/dev/null
  python -m pip install -r requirements-dev.txt && touch "$VENV/.deps-stamp"
fi

# Load local, gitignored config/secrets if present (TWITCH_*, DB_*, URLs, flags).
dotenv_if_exists .env

# NOTE: TensorFlow is intentionally NOT a local dependency (no py3.14 wheels).
# The model trainer and the prediction API run in Docker (python:3.12-slim);
# see Dockerfile.api and requirements-api.txt.
