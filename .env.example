# StreamerShield local configuration. Copy to `.env` (gitignored) and fill in.
# In production these are provided by the k8s ConfigMap + Secret instead.

# --- Twitch app credentials (secret) ---
TWITCH_APP_ID=your-app-id
TWITCH_APP_SECRET=your-app-secret

# --- Bot identity ---
TWITCH_USER=streamershield
ADMIN_USER=caesarlp

# --- Public URLs ---
# EventSub webhook callback host (served by the bot) and OAuth redirect.
EVENTSUB_URL=https://eventsub.caes.ar
AUTH_URL=https://shield.caes.ar/login/confirm
# The model/prediction API. Locally this is the Flask app; in-cluster it's the API service.
SHIELD_URL=http://localhost:38080/api/predict

# --- Behaviour ---
IS_ARMED=false          # when false, never sets a suspicious status (observe-only)
COLLECT_DATA=true       # persist an observation row for every checked user
AGE_THRESHOLD=6         # months; older accounts skip the model
MAX_LENGTH=29           # model username sequence length (must match the trained model)
CONF_RESTRICT=0.9       # confidence >= this -> "restricted"
CONF_MONITOR=0.5        # confidence >= this (and < restrict) -> "active_monitoring"
ENABLE_CLI=true         # run the interactive stdin CLI locally (kept false/off in k8s)

# --- Database (Postgres / CloudNativePG) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=streamer_shield
DB_USER=streamer_shield_user
DB_PASSWORD=changeme
DB_SSLMODE=require      # use "disable" for a local non-TLS Postgres

# --- API process only ---
PORT=38080

# --- Dashboard sessions (signs the session cookie; keep stable + secret) ---
FLASK_SECRET=change-me-to-a-long-random-string

# --- Logging ---
LOG_JSON=false
